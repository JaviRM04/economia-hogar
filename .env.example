# ============================================
# ECONOMÍA DEL HOGAR — Variables de entorno
# ============================================
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a git

# --- Base de datos ---
DATABASE_URL="postgresql://economia:economia@localhost:5432/economia"

# --- JWT ---
# Genera un secreto seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro

# --- Anthropic (para el bot) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram Bot ---
# Crea el bot en @BotFather y copia el token
TELEGRAM_BOT_TOKEN=
# ID numérico del grupo (añade @userinfobot al grupo para obtenerlo)
TELEGRAM_GROUP_ID=
# IDs de los dos usuarios (envía mensaje a @userinfobot para obtener el tuyo)
TELEGRAM_USER1_ID=
TELEGRAM_USER2_ID=
# Nombres (para el bot)
TELEGRAM_USER1_NAME=Usuario1
TELEGRAM_USER2_NAME=Usuario2

# --- Ngrok (solo desarrollo, para webhook Telegram) ---
# Deja vacío en producción
NGROK_URL=

# --- App ---
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
